#!/usr/bin/env node
/**
 * linear-ticket — minimal CLI for Linear issue ops, used by an orchestrator
 * agent for ticket-backed oversight of multi-agent work.
 *
 * Pure Node — built-in `fetch` (Node ≥ 20) and stdlib only. No `npm install`
 * needed for this file to run.
 *
 * Reads:
 *   ~/.openclaw/linear.json -> team_id, state IDs, api_key_secret_ref
 *
 * API key resolution order:
 *   1. $LINEAR_API_KEY  (override; useful for dev/CI)
 *   2. `op read <api_key_secret_ref>` (1Password; default if the ref is in
 *      linear.json)
 *
 * Subcommands:
 *   create   --title "..." [--description "..."] [--parent <id|key>] [--state <name>]
 *   update   <id|key> [--state <name>] [--title "..."] [--description "..."]
 *   comment  <id|key> --body "..."
 *   get      <id|key>
 *   list     [--state <name>] [--parent <id|key>] [--limit N]
 *
 * All output is JSON on stdout. Errors go to stderr with non-zero exit.
 *
 * State names map to UUIDs in ~/.openclaw/linear.json under `states`:
 *   backlog | todo | in_progress | in_review | done | canceled | duplicate
 */

import { readFile } from "node:fs/promises";
import { execFileSync } from "node:child_process";
import { homedir } from "node:os";
import { join } from "node:path";

const API_URL = "https://api.linear.app/graphql";
const CONFIG_PATH = join(homedir(), ".openclaw", "linear.json");

// ---------------------------------------------------------------------------
// Errors
// ---------------------------------------------------------------------------

function die(msg, code = 2) {
  process.stderr.write(msg.endsWith("\n") ? msg : msg + "\n");
  process.exit(code);
}

// ---------------------------------------------------------------------------
// Config + API key
// ---------------------------------------------------------------------------

async function loadConfig() {
  let raw;
  try {
    raw = await readFile(CONFIG_PATH, "utf-8");
  } catch (err) {
    if (err && err.code === "ENOENT") {
      die(`missing ${CONFIG_PATH}. Copy linear.json.template and fill it in.`);
    }
    die(`failed to read ${CONFIG_PATH}: ${err.message}`);
  }
  let cfg;
  try {
    cfg = JSON.parse(raw);
  } catch (err) {
    die(`${CONFIG_PATH} is not valid JSON: ${err.message}`);
  }
  const apiKey = resolveApiKey(cfg);
  return { apiKey, cfg };
}

function resolveApiKey(cfg) {
  const envKey = process.env.LINEAR_API_KEY;
  if (envKey) return envKey;
  const ref = cfg.api_key_secret_ref;
  if (!ref) {
    die("no api_key_secret_ref in linear.json and LINEAR_API_KEY not set");
  }
  try {
    return execFileSync("op", ["read", ref], {
      encoding: "utf-8",
      timeout: 15_000,
      stdio: ["ignore", "pipe", "pipe"],
    }).trim();
  } catch (err) {
    if (err.code === "ENOENT") {
      die("op CLI not found; install 1Password CLI or set LINEAR_API_KEY");
    }
    if (err.signal === "SIGTERM") {
      die("op read timed out");
    }
    const stderr = err.stderr ? err.stderr.toString().trim() : "";
    die(`op read failed (exit ${err.status ?? "?"}): ${stderr}`);
  }
  // Unreachable.
  return "";
}

// ---------------------------------------------------------------------------
// GraphQL
// ---------------------------------------------------------------------------

async function gql(apiKey, query, variables) {
  let response;
  try {
    response = await fetch(API_URL, {
      method: "POST",
      headers: { Authorization: apiKey, "Content-Type": "application/json" },
      body: JSON.stringify({ query, variables: variables ?? {} }),
    });
  } catch (err) {
    die(`Linear API unreachable: ${err.message}`);
  }
  if (!response.ok) {
    const body = await response.text().catch(() => "");
    die(`Linear API HTTP ${response.status}: ${body}`);
  }
  const payload = await response.json();
  if (payload.errors) {
    process.stderr.write(JSON.stringify(payload.errors, null, 2) + "\n");
    process.exit(2);
  }
  return payload.data;
}

function resolveStateId(cfg, name) {
  const key = name.toLowerCase().replace(/[\s-]/g, "_");
  if (!cfg.states || !(key in cfg.states)) {
    die(`unknown state: ${key}. valid: ${Object.keys(cfg.states ?? {}).join(", ")}`);
  }
  return cfg.states[key];
}

async function resolveIssueId(apiKey, ref) {
  // Treat anything with "-" (and not a URN) as a Linear issue key like "ENG-12".
  if (ref.includes("-") && !ref.startsWith("urn")) {
    const data = await gql(
      apiKey,
      "query($key: String!) { issue(id: $key) { id identifier title } }",
      { key: ref },
    );
    if (!data.issue) die(`issue not found: ${ref}`);
    return data.issue.id;
  }
  return ref;
}

// ---------------------------------------------------------------------------
// Subcommands
// ---------------------------------------------------------------------------

function requireString(args, key, where) {
  const v = args[key];
  if (typeof v !== "string" || v.length === 0) {
    die(`--${key} is required for \`${where}\` and must be a non-empty string`);
  }
  return v;
}

function optionalString(args, key, { allowEmpty = false } = {}) {
  const v = args[key];
  if (v === undefined) return undefined;
  if (typeof v !== "string") {
    die(`--${key}, if provided, must be a string`);
  }
  if (!allowEmpty && v.length === 0) {
    die(`--${key}, if provided, must be a non-empty string`);
  }
  return v;
}

async function cmdCreate(args) {
  const { apiKey, cfg } = await loadConfig();
  const title = requireString(args, "title", "create");
  const description = optionalString(args, "description");
  const stateName = optionalString(args, "state");
  const parent = optionalString(args, "parent");
  const stateId = stateName ? resolveStateId(cfg, stateName) : cfg.states.todo;
  const input = {
    teamId: cfg.team_id,
    title,
    description: description ?? "",
    stateId,
  };
  if (parent) input.parentId = await resolveIssueId(apiKey, parent);
  const data = await gql(
    apiKey,
    `mutation($input: IssueCreateInput!) {
       issueCreate(input: $input) {
         success
         issue { id identifier title url state { name } parent { identifier } }
       }
     }`,
    { input },
  );
  process.stdout.write(JSON.stringify(data.issueCreate.issue, null, 2) + "\n");
}

async function cmdUpdate(args) {
  const { apiKey, cfg } = await loadConfig();
  if (typeof args.ref !== "string" || !args.ref) die("update requires an issue id or key");
  const stateName = optionalString(args, "state");
  const title = optionalString(args, "title");
  // Permit `--description ""` so operators can clear an existing description.
  const description = optionalString(args, "description", { allowEmpty: true });
  const issueId = await resolveIssueId(apiKey, args.ref);
  const input = {};
  if (stateName) input.stateId = resolveStateId(cfg, stateName);
  if (title) input.title = title;
  if (description !== undefined) input.description = description;
  if (Object.keys(input).length === 0) die("nothing to update");
  const data = await gql(
    apiKey,
    `mutation($id: String!, $input: IssueUpdateInput!) {
       issueUpdate(id: $id, input: $input) {
         success
         issue { id identifier title url state { name } }
       }
     }`,
    { id: issueId, input },
  );
  process.stdout.write(JSON.stringify(data.issueUpdate.issue, null, 2) + "\n");
}

async function cmdComment(args) {
  const { apiKey } = await loadConfig();
  if (typeof args.ref !== "string" || !args.ref) die("comment requires an issue id or key");
  const body = requireString(args, "body", "comment");
  const issueId = await resolveIssueId(apiKey, args.ref);
  const data = await gql(
    apiKey,
    `mutation($input: CommentCreateInput!) {
       commentCreate(input: $input) {
         success
         comment { id body url }
       }
     }`,
    { input: { issueId, body } },
  );
  process.stdout.write(JSON.stringify(data.commentCreate.comment, null, 2) + "\n");
}

async function cmdGet(args) {
  const { apiKey } = await loadConfig();
  if (typeof args.ref !== "string" || !args.ref) die("get requires an issue id or key");
  const data = await gql(
    apiKey,
    `query($key: String!) {
       issue(id: $key) {
         id identifier title description url
         state { name type }
         parent { identifier title }
         children { nodes { identifier title state { name } } }
         comments { nodes { id body createdAt user { name } } }
       }
     }`,
    { key: args.ref },
  );
  if (!data.issue) die(`issue not found: ${args.ref}`);
  process.stdout.write(JSON.stringify(data.issue, null, 2) + "\n");
}

async function cmdList(args) {
  const { apiKey, cfg } = await loadConfig();
  const stateName = optionalString(args, "state");
  const parent = optionalString(args, "parent");
  const filter = { team: { id: { eq: cfg.team_id } } };
  if (stateName) filter.state = { id: { eq: resolveStateId(cfg, stateName) } };
  if (parent) {
    const parentUuid = await resolveIssueId(apiKey, parent);
    filter.parent = { id: { eq: parentUuid } };
  }
  const data = await gql(
    apiKey,
    `query($filter: IssueFilter, $first: Int!) {
       issues(filter: $filter, first: $first, orderBy: updatedAt) {
         nodes { identifier title url state { name } parent { identifier } }
       }
     }`,
    { filter, first: args.limit ?? 20 },
  );
  process.stdout.write(JSON.stringify(data.issues.nodes, null, 2) + "\n");
}

// ---------------------------------------------------------------------------
// Tiny argv parser (no deps)
// ---------------------------------------------------------------------------

// Known flags that take a value. Anything else listed as `--foo` with no
// value following is rejected, so `--body` without a string doesn't silently
// become `true` and slip past `if (!args.body)` checks downstream.
const STRING_FLAGS = new Set([
  "title",
  "description",
  "parent",
  "state",
  "body",
  "limit",
]);

function parseArgs(argv) {
  // argv comes in as process.argv.slice(2)
  const subcommand = argv[0];
  const rest = argv.slice(1);
  const out = { _: [] };
  for (let i = 0; i < rest.length; i++) {
    const tok = rest[i];
    if (tok.startsWith("--")) {
      const key = tok.slice(2);
      const next = rest[i + 1];
      const hasValue = next !== undefined && !next.startsWith("--");
      if (STRING_FLAGS.has(key)) {
        if (!hasValue) die(`--${key} requires a value`);
        out[toCamel(key)] = next;
        i += 1;
      } else if (hasValue) {
        // Unknown flag with a value — accept as string for forward-compat.
        out[toCamel(key)] = next;
        i += 1;
      } else {
        // Unknown bare flag — treat as boolean.
        out[toCamel(key)] = true;
      }
    } else {
      out._.push(tok);
    }
  }
  // Positional ref for update/comment/get
  if (out._.length > 0) out.ref = out._[0];
  if (out.limit !== undefined) {
    const n = Number(out.limit);
    if (!Number.isInteger(n) || n <= 0) die(`--limit must be a positive integer, got "${out.limit}"`);
    out.limit = n;
  }
  return { subcommand, args: out };
}

function toCamel(key) {
  return key.replace(/-([a-z])/g, (_m, c) => c.toUpperCase());
}

function printHelp() {
  process.stdout.write(
    `Usage:
  linear-ticket create   --title "..." [--description "..."] [--parent <id|key>] [--state <name>]
  linear-ticket update   <id|key>      [--state <name>] [--title "..."] [--description "..."]
  linear-ticket comment  <id|key>      --body "..."
  linear-ticket get      <id|key>
  linear-ticket list     [--state <name>] [--parent <id|key>] [--limit N]

State names: backlog | todo | in_progress | in_review | done | canceled | duplicate
Config:      ~/.openclaw/linear.json   (template at tools/linear.json.template)
Auth:        $LINEAR_API_KEY override, else op read <api_key_secret_ref>
`,
  );
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

const COMMANDS = {
  create: cmdCreate,
  update: cmdUpdate,
  comment: cmdComment,
  get: cmdGet,
  list: cmdList,
};

async function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0 || argv[0] === "-h" || argv[0] === "--help") {
    printHelp();
    process.exit(argv.length === 0 ? 2 : 0);
  }
  const { subcommand, args } = parseArgs(argv);
  const fn = COMMANDS[subcommand];
  if (!fn) die(`unknown subcommand: ${subcommand}`);
  await fn(args);
}

main().catch((err) => {
  die(`linear-ticket: ${err.stack ?? err.message ?? String(err)}`);
});
