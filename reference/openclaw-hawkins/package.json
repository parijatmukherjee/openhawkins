{
  "name": "openclaw-hawkins",
  "version": "1.0.9",
  "description": "openclaw-hawkins — durable orchestration (VINES) + shared agent memory (VECNA) for OpenClaw. Ships as an OpenClaw plugin and as a standalone CLI.",
  "license": "MIT",
  "author": "Parijat Mukherjee",
  "homepage": "https://github.com/parijatmukherjee/openclaw-hawkins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parijatmukherjee/openclaw-hawkins.git"
  },
  "bugs": {
    "url": "https://github.com/parijatmukherjee/openclaw-hawkins/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.0",
      "minGatewayVersion": "2026.5.0"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  },
  "bin": {
    "vines": "./dist/cli.js",
    "vecna": "./dist/hive/cli.js"
  },
  "files": [
    "dist",
    "vines/spec.md",
    "vines/schema.sql",
    "vecna/spec.md",
    "vecna/schema.sql",
    "scripts/bootstrap-vines-db.sh",
    "scripts/bootstrap-vecna-db.sh",
    "agents",
    "orchestrator/HAWKINS_PROTOCOL.md",
    "openclaw.plugin.json",
    "README.md",
    "INSTALL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawhub",
    "agentic",
    "orchestration",
    "linear",
    "mariadb",
    "swarm",
    "supervisor",
    "vines",
    "vecna",
    "hawkins",
    "knowledge-sharing",
    "hive-mind"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "smoke": "vitest run --config vitest.smoke.config.ts",
    "lint": "eslint src tests",
    "format": "prettier --write \"{src,tests}/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"{src,tests}/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .vitest-cache",
    "prepublishOnly": "npm run clean && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "mariadb": "^3.4.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "openclaw": "^2026.5.7",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
